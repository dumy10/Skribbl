   <widget class="QPushButton" name="SendMesageButton">
    <property name="geometry">
     <rect>
      <x>1000</x>
      <y>640</y>
      <width>71</width>
      <height>51</height>
     </rect>
    </property>
    <property name="styleSheet">
     <string notr="true">QPushButton {
background:transparent;
    background-color: rgb(255, 255, 255);
    color: rgb(0, 0, 0); /* text negru */
    border-style: solid;
    border-width: 2px;
    border-radius: 10px; /* colțuri rotunjite */
    border-color: rgba(0, 0, 0, 150);
    padding: 5px;
    font-size: 16px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: rgba(255, 255, 255, 200); /* mai puțin transparent când treci cu mouse-ul peste */
}

QPushButton:pressed {
    background-color: rgba(255, 255, 255, 100); /* mai transparent când este apăsat */
}
</string>
    </property>
    <property name="text">
     <string>send</string>
    </property>
